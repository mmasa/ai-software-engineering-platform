{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asep.dev/schemas/risk.schema.json",
  "title": "ASEP Risk",
  "description": "A risk tracked by the platform's risk model. Risks are mitigated by Controls. Scoring uses a simple, framework-agnostic qualitative scale in Phase 1.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "id", "title", "likelihood", "impact"],
  "properties": {
    "apiVersion": { "type": "string", "const": "asep.dev/v1alpha1" },
    "kind": { "type": "string", "const": "Risk" },
    "id": { "$ref": "https://asep.dev/schemas/common/identifiers.schema.json#/$defs/RiskId" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "likelihood": { "type": "string", "enum": ["low", "medium", "high"] },
    "impact": { "type": "string", "enum": ["low", "medium", "high"] },
    "status": {
      "type": "string",
      "enum": ["open", "mitigated", "accepted", "closed"],
      "default": "open"
    },
    "mitigatedBy": {
      "type": "array",
      "items": { "$ref": "https://asep.dev/schemas/common/identifiers.schema.json#/$defs/ControlId" },
      "uniqueItems": true
    }
  }
}
